SELECT sac.stc_person_id, SUM(sac.stc_cred)
FROM student_acad_cred sac
LEFT JOIN courses c
  ON sac.stc_course_name = c.crs_name
WHERE c.crs_standard_articulation_no LIKE 'IAI%'
  AND (
        sac.stc_cum_contrib_grade_pts > 1
        OR (sac.stc_term IS NULL AND sac.stc_verified_grade = '49')
      )
  AND sac.stc_person_id IN (
        SELECT sac2.stc_person_id
        FROM student_acad_cred sac2
        JOIN course_sections_ls cs
          ON '*' || sac2.stc_term || '*' || sac2.stc_course_name || '-' || sac2.stc_section_no
             = cs.sec_section_idx
         AND cs.pos = 1
        WHERE cs.sec_local_govt_codes = '11'
          AND sac2.stc_term IN ('2025FA','2025SU','2025SP')
      )
GROUP BY sac.stc_person_id
HAVING SUM(sac.stc_cred) > 29.5;
