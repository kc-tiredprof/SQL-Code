select DISTINCT
left(AP.ACAD_PROGRAMS_ID,4)
--,ACPG_DEGREE
--,ACPG_CIP
FROM dbo.ACAD_PROGRAMS AP
LEFT OUTER JOIN ACAD_PROGRAMS_LS APLS ON APLS.ACAD_PROGRAMS_ID = AP.ACAD_PROGRAMS_ID
LEFT OUTER JOIN dbo.MAJORS ON MAJORS_ID = ACPG_MAJORS
WHERE ACPG_END_DATE IS NULL
AND MAJ_DIVISION = 'CT'
--AND ACPG_DEGREE IS NOT NULL
AND AP.ACAD_PROGRAMS_ID NOT LIKE '%ENRL'
AND AP.ACAD_PROGRAMS_ID NOT LIKE '%DUAL'
order by left(AP.ACAD_PROGRAMS_ID,4)
